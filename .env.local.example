# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Auth
# Set to "true" to allow any Google account (not just @asu.edu) for testing
NEXT_PUBLIC_ALLOW_TEST_ACCOUNTS=false

# Create AI (ASU AI/ML Platform) — powers "Suggest tools" on activity pages
CREATE_AI_API_KEY=
CREATE_AI_API_URL=https://api-main.aiml.asu.edu/query
CREATE_AI_MODEL=claude4_5_sonnet
CREATE_AI_PROVIDER=aws

